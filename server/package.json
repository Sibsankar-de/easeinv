{
  "name": "ease-inv-server",
  "version": "1.0.0",
  "description": "EaseInv Server",
  "keywords": [
    "backend"
  ],
  "license": "ISC",
  "author": "sibsankar",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:generate": "prisma generate --schema=prisma/schema",
    "db:migrate": "prisma migrate dev --schema=prisma/schema",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema",
    "db:studio": "prisma studio --schema=prisma/schema",
    "db:reset": "prisma migrate reset --schema=prisma/schema"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqplib": "^2.0.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mjml": "^5.2.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.8",
    "pg": "^8.22.0",
    "uuid": "^11.1.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/handlebars": "^4.0.40",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mjml": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
